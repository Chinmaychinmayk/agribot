        <material>
          <ambient>0.5 0.35 0.2 1</ambient>
          <diffuse>0.57 0.6 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="bed_collision">
        <geometry><box><size>10.0 0.5 0.1</size></box></geometry>
      </collision>
    </link>
  </model>

