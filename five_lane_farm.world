  <!-- =================== HUSKY A200 FOOTPRINT REFERENCE ===================
       A flat, semi-transparent footprint (0.99 m x 0.67 m, the Husky's real
       footprint) dropped at the entrance of lane_1. It is NOT a functioning
       robot model, just a scale reference so you can visually confirm fit.
       Delete this model, or replace it with an actual Husky model include,
       once you spawn the real robot.
       =================================================================== -->

  <model name="husky_footprint_start_reference">
    <static>true</static>
    <link name="footprint_link">
      <pose>5.8 -3.0 0.025 0 0 0</pose>
      <visual name="footprint_visual">
        <geometry><box><size>0.99 0.67 0.02</size></box></geometry>
        <material>
          <ambient>0.1 0.3 0.9 0.6</ambient>
          <diffuse>0.1 0.3 0.9 0.6</diffuse>
        </material>
        <transparency>0.4</transparency>
      </visual>
    </link>
  </model>

  <model name="husky_footprint_end_reference">
    <static>true</static>
    <link name="footprint_link">
      <pose>-5.8 2.7 0.025 0 0 0</pose>
      <visual name="footprint_visual">
        <geometry><box><size>0.99 0.67 0.02</size></box></geometry>
        <material>
          <ambient>0.1 0.5 0.05 1</ambient>
          <diffuse>0.1 0.5 0.05 1</diffuse>
        </material>
        <transparency>0.4</transparency>
      </visual>
    </link>
  </model>

