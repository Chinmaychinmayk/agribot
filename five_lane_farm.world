  <!-- ===================== FALLEN PLANT - BLOCKS A LANE =====================
       A toppled plant lying across lane_5_uniform (y = 2.7), matching the
       sketch's "plant fallen" note. The stem cylinder is rotated 90 deg
       about X so it lies flat across the lane's 1.0 m width, with real
       collision geometry so it actually obstructs the Husky in simulation.
       Move it to a different lane by changing the y value, or to a
       different point along the lane by changing the x value.
       ===================================================================== -->

  <model name="fallen_plant_lane5">
    <static>true</static>
    <link name="fallen_link">

      <!-- toppled stem, lying across the lane -->
      <pose>3.0 2.7 0.07 1.5708 0 0</pose>
      <visual name="fallen_stem_visual">
        <geometry><cylinder><radius>0.05</radius><length>0.9</length></cylinder></geometry>
        <material>
          <ambient>0.4 0.25 0.1 1</ambient>
          <diffuse>0.4 0.25 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="fallen_stem_collision">
        <geometry><cylinder><radius>0.05</radius><length>0.9</length></cylinder></geometry>
      </collision>
    </link>

    <!-- foliage clump at one end of the fallen stem -->
    <link name="fallen_foliage_link">
      <pose>3.0 3.15 0.20 0 0 0</pose>
      <visual name="fallen_foliage_visual">
        <geometry><sphere><radius>0.18</radius></sphere></geometry>
        <material>
          <ambient>0.1 0.5 0.05 1</ambient>
          <diffuse>0.1 0.5 0.05 1</diffuse>
        </material>
      </visual>
      <collision name="fallen_foliage_collision">
        <geometry><sphere><radius>0.18</radius></sphere></geometry>
      </collision>
    </link>
  </model>

</world>
</sdf>
