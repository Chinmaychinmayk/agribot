<?xml version="1.0" ?>
<sdf version="1.6">
<world name="five_lane_farm_world">

  <!-- =====================================================================
       FIVE-LANE FARM WORLD
       Robot reference: Clearpath Husky A200
         length 0.99 m | width 0.67 m | height 0.39 m | track 0.555 m
       Source: Clearpath Husky A200 User Manual, Table 2 (Key Specifications)

       Design rule used below:
         UNIFORM_LANE_WIDTH = 1.0 m   -> robot width (0.67 m) + 0.15 m clearance
                                         per side. Husky can drive straight
                                         through these lanes.
         NARROW_LANE_WIDTH  = 0.4 m   -> less than the robot's 0.67 m width.
                                         Husky physically cannot enter/exit
                                         this lane (matches the "Narrow -
                                         can't enter/exit" note in the sketch).

       Layout along the Y axis (5 lanes separated/bordered by 6 plant beds):

         bed0 | lane1 (1.0 m) | bed1 | lane2 (1.0 m) | bed2 |
         lane3 (0.4 m, NARROW) | bed3 | lane4 (1.0 m) | bed4 |
         lane5 (1.0 m) | bed5

       All lanes and beds run the full 10 m length of the farm (X axis).
       To change a lane's width, just edit its <size> Y value and re-center
       the Y positions of everything to its right.
       ===================================================================== -->

  <!-- ============================ PLANT BEDS ============================ -->

  <model name="plant_bed_0">
    <static>true</static>
    <link name="bed_link">
      <pose>0 -3.75 0.05 0 0 0</pose>
      <visual name="bed_visual">
        <geometry><box><size>10.0 0.5 0.1</size></box></geometry>
        <material>
          <ambient>0.5 0.35 0.2 1</ambient>
          <diffuse>0.47 0.5 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="bed_collision">
        <geometry><box><size>10.0 0.5 0.1</size></box></geometry>
      </collision>
    </link>
  </model>

  <model name="plant_bed_1">
    <static>true</static>
    <link name="bed_link">
      <pose>0 -1.95 0.05 0 0 -0.08</pose>
      <visual name="bed_visual">
        <geometry><box><size>10.0 0.5 0.1</size></box></geometry>
        <material>
          <ambient>0.5 0.35 0.2 1</ambient>
          <diffuse>0.5 0.6 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="bed_collision">
        <geometry><box><size>10.0 0.5 0.1</size></box></geometry>
      </collision>
    </link>
  </model>

